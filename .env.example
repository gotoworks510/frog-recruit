# =========================================================================
# frog-recruit — local development env (.env.local)
# Copy to .env.local and fill in. NEVER commit real values.
# =========================================================================

# --- NextAuth / Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3005

# Admin allow-list (comma separated). Single source of truth for admin role.
ADMIN_EMAILS=senna@frogagent.com

# --- Email (Resend) ---
RESEND_API_KEY=
# frogagent.com is not yet Resend-verified; send from the verified japan.frogagent.com.
RECRUIT_FROM_EMAIL=Frog Recruit <recruit@japan.frogagent.com>

# --- Local dev: D1 over HTTP proxy (point at a DEV/STAGING D1, never prod) ---
CLOUDFLARE_ACCOUNT_ID=fdeca1d02dc8d3502bdb515b9be7ec9c
CLOUDFLARE_API_TOKEN=
DEV_D1_DATABASE_ID=
# Set to 1 ONLY if you deliberately want dev to hit the production D1 (dangerous).
D1_ALLOW_PROD_IN_DEV=

# --- Local dev: R2 over S3 proxy ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Base URL used in emails / links during dev
PUBLIC_BASE_URL=http://localhost:3005
