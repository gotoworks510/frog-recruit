{
  "name": "frog-recruit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "next build",
    "build:worker": "npx @opennextjs/cloudflare build",
    "deploy": "npm run build:worker && wrangler deploy",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:schema": "wrangler d1 execute frog-recruit-db --local --file=scripts/migrations/0001_init.sql",
    "db:seed": "wrangler d1 execute frog-recruit-db --local --file=scripts/seed.sql",
    "db:setup": "npm run db:schema && npm run db:seed",
    "db:reset": "wrangler d1 execute frog-recruit-db --local --file=scripts/reset.sql && npm run db:setup",
    "db:schema:remote": "wrangler d1 execute frog-recruit-db --remote --file=scripts/migrations/0001_init.sql",
    "db:seed:remote": "wrangler d1 execute frog-recruit-db --remote --file=scripts/seed.sql",
    "db:migrate:remote": "wrangler d1 execute frog-recruit-db --remote --file",
    "db:exec:remote": "wrangler d1 execute frog-recruit-db --remote --command"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.469.0",
    "next": "15.5.18",
    "next-auth": "^5.0.0-beta.25",
    "pdf-lib": "^1.17.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.0.0"
  }
}
